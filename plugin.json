{
  "name": "oh-my-kimi",
  "version": "2.0.0",
  "description": "Oh My Kimi - 为 Kimi CLI 提供增强功能和实用工具，源自 oh-my-opencode",
  "tools": [
    {
      "name": "smart_glob",
      "description": "基于模式匹配查找文件，支持 **/*.py 等 glob 模式",
      "command": ["python3", "scripts/smart_glob.py"],
      "parameters": {
        "type": "object",
        "properties": {
          "pattern": {
            "type": "string",
            "description": "文件匹配模式，如 '**/*.py', 'src/**/*.ts'"
          },
          "path": {
            "type": "string",
            "description": "搜索目录，默认为当前工作目录"
          },
          "limit": {
            "type": "number",
            "description": "返回结果数量限制，0 表示无限制",
            "default": 100
          }
        },
        "required": ["pattern"]
      }
    },
    {
      "name": "smart_grep",
      "description": "基于正则表达式搜索文件内容，支持多种输出模式",
      "command": ["python3", "scripts/smart_grep.py"],
      "parameters": {
        "type": "object",
        "properties": {
          "pattern": {
            "type": "string",
            "description": "正则表达式搜索模式"
          },
          "include": {
            "type": "string",
            "description": "文件类型过滤，如 '*.py', '*.{ts,tsx}'"
          },
          "path": {
            "type": "string",
            "description": "搜索目录，默认为当前工作目录"
          },
          "output_mode": {
            "type": "string",
            "enum": ["content", "files_with_matches", "count"],
            "description": "输出模式：content 显示匹配行，files_with_matches 仅显示文件路径，count 显示匹配数量",
            "default": "files_with_matches"
          },
          "head_limit": {
            "type": "number",
            "description": "输出结果数量限制，0 表示无限制",
            "default": 0
          }
        },
        "required": ["pattern"]
      }
    },
    {
      "name": "github_triage",
      "description": "分析 GitHub 仓库的 Issues 和 PRs，获取列表和统计信息",
      "command": ["python3", "scripts/github_triage.py"],
      "parameters": {
        "type": "object",
        "properties": {
          "repo": {
            "type": "string",
            "description": "GitHub 仓库名称 (owner/repo 格式，如 'code-yeongyu/oh-my-openagent')"
          },
          "item_type": {
            "type": "string",
            "enum": ["issues", "prs", "all"],
            "description": "获取类型：issues 仅 issues，prs 仅 PRs，all 两者都获取",
            "default": "all"
          },
          "state": {
            "type": "string",
            "enum": ["open", "closed", "all"],
            "description": "状态过滤",
            "default": "open"
          },
          "output_format": {
            "type": "string",
            "enum": ["json", "summary"],
            "description": "输出格式：json 返回完整数据，summary 返回摘要统计",
            "default": "summary"
          }
        },
        "required": ["repo"]
      }
    },
    {
      "name": "code_analyze",
      "description": "分析 Python 代码结构，统计函数、类、导入等信息",
      "command": ["python3", "scripts/code_analyze.py"],
      "parameters": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "description": "要分析的代码文件或目录路径"
          },
          "include_tests": {
            "type": "boolean",
            "description": "是否包含测试文件 (test_*.py, *_test.py)",
            "default": false
          }
        },
        "required": ["path"]
      }
    },
    {
      "name": "project_stats",
      "description": "统计项目代码量和结构，按语言、目录分组统计",
      "command": ["python3", "scripts/project_stats.py"],
      "parameters": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "description": "项目目录路径，默认为当前工作目录"
          },
          "exclude": {
            "type": "string",
            "description": "排除模式，逗号分隔，如 'node_modules,*.pyc,__pycache__,.git'",
            "default": "node_modules,__pycache__,.git,venv,.venv,dist,build"
          }
        }
      }
    }
  ]
}
